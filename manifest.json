{
  "manifest_version": 3,
  "key": "",
  "name": "CSV Notes",
  "version": "2.0.0",
  "description": "Manage CSV files in a spreadsheet-like popup interface with cloud sync.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://*.supabase.co/*"
  ]
}