{
  "manifest_version": 3,
  "name": "CSV Notes",
  "version": "1.0.0",
  "description": "Manage CSV files in a spreadsheet-like popup interface.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage"
  ]
}
